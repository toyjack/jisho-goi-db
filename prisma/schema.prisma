generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Hzwm {
  id         String  @id
  location   String?
  type       String?
  entry      String?
  definition String?
  readings   String?
  createdAt  String?
  updatedAt  String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Account {
  id                String  @id
  userId            String?
  provider          String?
  providerAccountId String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model BunmeiSetsuyoshu {
  id                BigInt  @id
  bunmei_id         String @unique
  gotou             String?
  entry             String?
  entry_original    String?
  gokei             String?
  gokei_original    String?
  left_kun          String?
  left_kun_original String?
  definition        String?
  item_type         String?
  bu                String?
  mon               String?
  page              BigInt?
  line              BigInt?
  ndl_link          String?
  remark            String?
  ndl_comma         String?
  no_inline         BigInt?
  revision          String?
  shoten            String?
  shoten_original   String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Gyokuhentaizen {
  id             BigInt  @id
  ghtz_id        String @unique
  entry          String?
  jion_r         String?
  jion_l         String?
  wakun          String?
  ids            String?
  radical        String?
  remain_strokes String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Jiruisho {
  id                    BigInt  @id
  entry                 String?
  entry_expression      String?
  shouten               String?
  hen                   String?
  bu                    String?
  maeda_loc             String?
  maeda_ndl_url         String?
  kurokawa_loc          String?
  kurokawa_ndl_url      String?
  onkun                 String?
  char_count            BigInt?
  gokei_display         String?
  gokei_search_original String?
  gokei_search_current  String?
  remark                String?
  definition            String?
  chushaku             JiruishoChushaku?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model JiruishoChushaku {
  id               BigInt  @id
  maki             String?
  hen              String?
  bu               String?
  annotation       String?
  word_in_kurokawa String?
  word_in_maeda    String?
  jiruisho_id      BigInt @unique
  jiruisho         Jiruisho @relation(fields: [jiruisho_id], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Racvyoxv {
  id             String  @id
  page           BigInt?
  line           BigInt?
  gallica        String?
  entry          String?
  remark         String?
  nikkoku1_entry String?
  nikkoku1_url   String?
  nikkoku2_entry String?
  nikkoku2_url   String?
  nikkoku3_entry String?
  nikkoku3_url   String?
  nikkoku4_entry String?
  nikkoku4_url   String?
  nikkoku5_entry String?
  nikkoku5_url   String?
  nikkoku6_entry String?
  nikkoku6_url   String?
  nikkoku7_entry String?
  nikkoku7_url   String?
  bu             String?
  entry_length   BigInt?
  kun            String?
  nikkoku8_entry String?
  nikkoku8_url   String?
  on             String?
  gokei          String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id        String  @id
  email     String?
  name      String?
  password  String?
  createdAt String?
  updatedAt String?
  role      String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Wakunnosiori_Def {
  id         BigInt              @id
  index      BigInt?
  entry_id   BigInt?
  definition String?
  entry      Wakunnosiori_Entry? @relation(fields: [entry_id], references: [id])

  @@index([entry_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Wakunnosiori_Entry {
  id          BigInt             @id
  entry       String?
  location    String?
  ndl_url     String?
  page        String?
  definitions Wakunnosiori_Def[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Wamyouruijyusho {
  id         BigInt  @id
  maki       String?
  bu         String?
  type       String?
  type2      String?
  page       String?
  entry      String?
  definition String?
}
